<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KazoOCR.UI.MainPage"
             Title="KazoOCR"
             x:Name="ThisPage">
    <Grid Padding="20" RowSpacing="15" ColumnSpacing="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="150" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <Label Grid.Row="0" Grid.ColumnSpan="2"
               Text="KazoOCR - PDF OCR Processing"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,0,0,10" />

        <!-- Drop Zone -->
        <Border Grid.Row="1" Grid.Column="0"
                x:Name="DropZone"
                Stroke="#512BD4"
                StrokeThickness="2"
                StrokeDashArray="5,3"
                BackgroundColor="#F5F5F5"
                Padding="20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- File List or Drop Instruction -->
                <VerticalStackLayout Grid.Row="0" VerticalOptions="Center" HorizontalOptions="Center"
                                     IsVisible="{Binding PendingFiles.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=inverse}">
                    <Label Text="📄" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="Drag &amp; Drop PDF Files Here" FontSize="18" HorizontalOptions="Center" />
                    <Label Text="or use the buttons below" FontSize="14" TextColor="Gray" HorizontalOptions="Center" />
                </VerticalStackLayout>

                <CollectionView Grid.Row="0" ItemsSource="{Binding PendingFiles}"
                                IsVisible="{Binding PendingFiles.Count, Converter={StaticResource IntToVisibilityConverter}}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Text="📄" FontSize="16" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding}" FontSize="14" VerticalOptions="Center" Margin="5,0,0,0" LineBreakMode="MiddleTruncation" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- File Selection Buttons -->
                <HorizontalStackLayout Grid.Row="1" HorizontalOptions="Center" Spacing="10">
                    <Button x:Name="SelectFilesButton"
                            Text="Select Files"
                            Clicked="OnSelectFilesClicked"
                            IsEnabled="{Binding IsNotProcessing}"
                            WidthRequest="120" />
                    <Button x:Name="SelectFolderButton"
                            Text="Select Folder"
                            Clicked="OnSelectFolderClicked"
                            IsEnabled="{Binding IsNotProcessing}"
                            WidthRequest="120" />
                    <Button x:Name="ClearFilesButton"
                            Text="Clear"
                            Clicked="OnClearFilesClicked"
                            IsEnabled="{Binding IsNotProcessing}"
                            BackgroundColor="#E74C3C"
                            TextColor="White"
                            WidthRequest="80" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- OCR Options Panel -->
        <Border Grid.Row="1" Grid.Column="1"
                Stroke="#CCCCCC"
                StrokeThickness="1"
                BackgroundColor="#FAFAFA"
                Padding="15">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <ScrollView>
                <VerticalStackLayout Spacing="15">
                    <Label Text="OCR Options" FontSize="18" FontAttributes="Bold" />

                    <!-- Suffix -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Output Suffix:" FontSize="14" />
                        <Entry x:Name="SuffixEntry"
                               Text="{Binding Suffix}"
                               Placeholder="_OCR"
                               IsEnabled="{Binding IsNotProcessing}" />
                    </VerticalStackLayout>

                    <!-- Languages -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Languages:" FontSize="14" />
                        <Entry x:Name="LanguagesEntry"
                               Text="{Binding Languages}"
                               Placeholder="fra+eng"
                               IsEnabled="{Binding IsNotProcessing}" />
                        <Label Text="(e.g., fra+eng, deu, spa)" FontSize="11" TextColor="Gray" />
                    </VerticalStackLayout>

                    <!-- Checkboxes -->
                    <Label Text="Processing Options:" FontSize="14" Margin="0,10,0,0" />
                    
                    <HorizontalStackLayout Spacing="10">
                        <CheckBox x:Name="DeskewCheckBox"
                                  IsChecked="{Binding Deskew}"
                                  IsEnabled="{Binding IsNotProcessing}" />
                        <Label Text="Deskew" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox x:Name="CleanCheckBox"
                                  IsChecked="{Binding Clean}"
                                  IsEnabled="{Binding IsNotProcessing}" />
                        <Label Text="Clean (Unpaper)" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox x:Name="RotateCheckBox"
                                  IsChecked="{Binding Rotate}"
                                  IsEnabled="{Binding IsNotProcessing}" />
                        <Label Text="Auto-Rotate" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Optimize Slider -->
                    <VerticalStackLayout Spacing="5" Margin="0,10,0,0">
                        <HorizontalStackLayout>
                            <Label Text="Optimize Level: " FontSize="14" />
                            <Label Text="{Binding Optimize}" FontSize="14" FontAttributes="Bold" />
                        </HorizontalStackLayout>
                        <Slider x:Name="OptimizeSlider"
                                Minimum="0"
                                Maximum="3"
                                Value="{Binding Optimize}"
                                IsEnabled="{Binding IsNotProcessing}" />
                        <HorizontalStackLayout HorizontalOptions="Fill">
                            <Label Text="0 (None)" FontSize="10" TextColor="Gray" HorizontalOptions="Start" />
                            <Label Text="3 (Max)" FontSize="10" TextColor="Gray" HorizontalOptions="EndAndExpand" HorizontalTextAlignment="End" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <!-- Progress Section -->
        <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressBar Grid.Column="0"
                         x:Name="ProcessingProgressBar"
                         Progress="{Binding Progress, Converter={StaticResource PercentToProgressConverter}}"
                         ProgressColor="#512BD4"
                         HeightRequest="20" />

            <Button Grid.Column="1"
                    x:Name="ProcessButton"
                    Text="Process"
                    Clicked="OnProcessClicked"
                    IsEnabled="{Binding IsNotProcessing}"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    WidthRequest="100" />

            <Button Grid.Column="2"
                    x:Name="CancelButton"
                    Text="Cancel"
                    Clicked="OnCancelClicked"
                    IsEnabled="{Binding IsProcessing}"
                    BackgroundColor="#E74C3C"
                    TextColor="White"
                    WidthRequest="100" />
        </Grid>

        <!-- Log Output -->
        <Border Grid.Row="3" Grid.ColumnSpan="2"
                Stroke="#CCCCCC"
                StrokeThickness="1"
                BackgroundColor="#1E1E1E"
                Padding="10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="5" />
            </Border.StrokeShape>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <HorizontalStackLayout Grid.Row="0" Margin="0,0,0,5">
                    <Label Text="Log Output" FontSize="12" TextColor="#CCCCCC" VerticalOptions="Center" />
                    <Button Text="Clear"
                            FontSize="10"
                            Padding="5,2"
                            Margin="10,0,0,0"
                            Clicked="OnClearLogClicked"
                            BackgroundColor="#333333"
                            TextColor="#CCCCCC"
                            HeightRequest="25" />
                </HorizontalStackLayout>
                <CollectionView Grid.Row="1"
                                x:Name="LogListView"
                                ItemsSource="{Binding LogMessages}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Label Text="{Binding}"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   TextColor="#00FF00"
                                   Padding="2" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Label Grid.Row="4" Grid.ColumnSpan="2"
               x:Name="StatusLabel"
               Text="{Binding StatusMessage}"
               FontSize="12"
               TextColor="Gray"
               HorizontalOptions="Start" />
    </Grid>
</ContentPage>
