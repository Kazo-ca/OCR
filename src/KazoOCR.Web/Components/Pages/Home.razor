@page "/"
@inject IKazoApiClient ApiClient
@inject IJSRuntime JS
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>Dashboard - KazoOCR</PageTitle>

<AuthGuard>
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>OCR Jobs Dashboard</h1>
            <a href="/upload" class="btn btn-primary">
                <i class="bi bi-upload"></i> New Upload
            </a>
        </div>

        @if (_loading)
        {
            <div class="d-flex justify-content-center">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (_jobs.Count == 0)
        {
            <div class="alert alert-info">
                <h4 class="alert-heading">No jobs yet</h4>
                <p>Upload a PDF file to start processing with OCR.</p>
                <hr />
                <a href="/upload" class="btn btn-info">Upload PDF</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>File Name</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Completed</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in _jobs)
                        {
                            <tr>
                                <td>@job.FileName</td>
                                <td>
                                    <span class="badge @GetStatusBadgeClass(job.Status)">
                                        @job.Status
                                    </span>
                                </td>
                                <td>@job.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td>@(job.CompletedAt?.ToLocalTime().ToString("g") ?? "-")</td>
                                <td>
                                    @if (job.Status == JobStatus.Completed)
                                    {
                                        <span class="text-muted small" title="Download not yet implemented">
                                            <i class="bi bi-download"></i> (Coming soon)
                                        </span>
                                    }
                                    @if (job.Status == JobStatus.Failed)
                                    {
                                        <span class="text-danger small" title="@job.ErrorMessage">
                                            Error
                                        </span>
                                    }
                                    <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteJob(job.Id)">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="mt-3 text-muted small">
            <span>Auto-refresh every 2 seconds</span>
            @if (_lastRefresh.HasValue)
            {
                <span class="ms-2">Last updated: @_lastRefresh.Value.ToLocalTime().ToString("T")</span>
            }
        </div>
    </div>
</AuthGuard>

@code {
    private List<OcrJob> _jobs = [];
    private bool _loading = true;
    private DateTime? _lastRefresh;
    private CancellationTokenSource? _cts;
    private Task? _pollingTask;

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        await RefreshJobsAsync();

        // Start background polling using PeriodicTimer for thread safety
        _pollingTask = PollJobsAsync(_cts.Token);
    }

    private async Task PollJobsAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await RefreshJobsAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Expected during disposal
        }
    }

    private async Task RefreshJobsAsync()
    {
        try
        {
            var jobs = await ApiClient.GetJobsAsync(_cts?.Token ?? CancellationToken.None);
            _jobs = jobs.OrderByDescending(j => j.CreatedAt).ToList();
            _lastRefresh = DateTime.UtcNow;
        }
        catch (OperationCanceledException)
        {
            // Ignore expected cancellation during shutdown/disposal
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetStatusBadgeClass(JobStatus status) => status switch
    {
        JobStatus.Pending => "bg-secondary",
        JobStatus.Processing => "bg-primary",
        JobStatus.Completed => "bg-success",
        JobStatus.Failed => "bg-danger",
        _ => "bg-secondary"
    };

    private async Task DeleteJob(string jobId)
    {
        await ApiClient.DeleteJobAsync(jobId);
        await RefreshJobsAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_cts != null)
        {
            await _cts.CancelAsync();
            _cts.Dispose();
        }

        if (_pollingTask != null)
        {
            try
            {
                await _pollingTask;
            }
            catch (OperationCanceledException)
            {
                // Expected
            }
        }
    }
}
