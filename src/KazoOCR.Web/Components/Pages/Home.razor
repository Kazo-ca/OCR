@page "/"
@inject IKazoApiClient ApiClient
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Dashboard - KazoOCR</PageTitle>

<AuthGuard>
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>OCR Jobs Dashboard</h1>
            <a href="/upload" class="btn btn-primary">
                <i class="bi bi-upload"></i> New Upload
            </a>
        </div>

        @if (_loading)
        {
            <div class="d-flex justify-content-center">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (_jobs.Count == 0)
        {
            <div class="alert alert-info">
                <h4 class="alert-heading">No jobs yet</h4>
                <p>Upload a PDF file to start processing with OCR.</p>
                <hr />
                <a href="/upload" class="btn btn-info">Upload PDF</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>File Name</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Completed</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in _jobs)
                        {
                            <tr>
                                <td>@job.FileName</td>
                                <td>
                                    <span class="badge @GetStatusBadgeClass(job.Status)">
                                        @job.Status
                                    </span>
                                </td>
                                <td>@job.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td>@(job.CompletedAt?.ToLocalTime().ToString("g") ?? "-")</td>
                                <td>
                                    @if (job.Status == JobStatus.Completed)
                                    {
                                        <button class="btn btn-sm btn-success" @onclick="() => DownloadJob(job.Id)">
                                            Download
                                        </button>
                                    }
                                    @if (job.Status == JobStatus.Failed)
                                    {
                                        <span class="text-danger small" title="@job.ErrorMessage">
                                            Error
                                        </span>
                                    }
                                    <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteJob(job.Id)">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="mt-3 text-muted small">
            <span>Auto-refresh every 2 seconds</span>
            @if (_lastRefresh.HasValue)
            {
                <span class="ms-2">Last updated: @_lastRefresh.Value.ToLocalTime().ToString("T")</span>
            }
        </div>
    </div>
</AuthGuard>

@code {
    private List<OcrJob> _jobs = [];
    private bool _loading = true;
    private DateTime? _lastRefresh;
    private Timer? _timer;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        await RefreshJobsAsync();

        // Set up polling every 2 seconds
        _timer = new Timer(async _ =>
        {
            await RefreshJobsAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    private async Task RefreshJobsAsync()
    {
        try
        {
            var jobs = await ApiClient.GetJobsAsync(_cts?.Token ?? CancellationToken.None);
            _jobs = jobs.OrderByDescending(j => j.CreatedAt).ToList();
            _lastRefresh = DateTime.UtcNow;
        }
        catch (Exception)
        {
            // Ignore errors during polling
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetStatusBadgeClass(JobStatus status) => status switch
    {
        JobStatus.Pending => "bg-secondary",
        JobStatus.Processing => "bg-primary",
        JobStatus.Completed => "bg-success",
        JobStatus.Failed => "bg-danger",
        _ => "bg-secondary"
    };

    private async Task DeleteJob(string jobId)
    {
        await ApiClient.DeleteJobAsync(jobId);
        await RefreshJobsAsync();
    }

    private async Task DownloadJob(string jobId)
    {
        // In a real implementation, this would trigger a file download
        // For now, we'll just navigate to a download URL
        var job = _jobs.FirstOrDefault(j => j.Id == jobId);
        if (job != null)
        {
            // The download would be handled by the API
            await Task.CompletedTask;
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
