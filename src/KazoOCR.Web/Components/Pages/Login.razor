@page "/login"
@layout AuthLayout
@inject AuthStateService AuthState
@inject IKazoApiClient ApiClient
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Login - KazoOCR</PageTitle>

<h5 class="text-center mb-4">Sign In</h5>

@if (_showSetupSuccess)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle me-2"></i>
        Password configured successfully! Please sign in to continue.
    </div>
}

@if (_errorMessage != null)
{
    <div class="alert alert-danger">
        @_errorMessage
    </div>
}

<EditForm Model="_loginModel" OnValidSubmit="HandleLogin">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Password</label>
        <InputText type="password" @bind-Value="_loginModel.Password" class="form-control"
                   placeholder="Enter your password" autofocus />
        <ValidationMessage For="@(() => _loginModel.Password)" />
    </div>

    <div class="d-grid">
        <button type="submit" class="btn btn-primary" disabled="@_loading">
            @if (_loading)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            }
            Sign In
        </button>
    </div>
</EditForm>

<div class="mt-4 text-center">
    <small class="text-muted">
        KazoOCR Web Interface
    </small>
</div>

@code {
    private readonly LoginModel _loginModel = new();
    private bool _loading;
    private string? _errorMessage;
    private bool _showSetupSuccess;

    protected override async Task OnInitializedAsync()
    {
        // Check for setup success query parameter
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (System.Web.HttpUtility.ParseQueryString(uri.Query).Get("setup") == "success")
        {
            _showSetupSuccess = true;
        }

        // Check auth status - always check server-side, don't cache
        var status = await ApiClient.GetAuthStatusAsync();

        if (!status.Configured)
        {
            // First-run: redirect to setup
            Navigation.NavigateTo("/setup", forceLoad: true);
            return;
        }

        if (status.Authenticated)
        {
            // Already authenticated: redirect to dashboard
            Navigation.NavigateTo("/", forceLoad: true);
        }
    }

    private async Task HandleLogin()
    {
        _loading = true;
        _errorMessage = null;
        _showSetupSuccess = false; // Clear success message on login attempt

        try
        {
            var success = await AuthState.LoginAsync(_loginModel.Password);
            if (success)
            {
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                _errorMessage = "Invalid password. Please try again.";
            }
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"Login failed: {ex.Message}";
        }
        catch (TaskCanceledException)
        {
            _errorMessage = "Login request timed out. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private sealed class LoginModel
    {
        public string Password { get; set; } = string.Empty;
    }
}
